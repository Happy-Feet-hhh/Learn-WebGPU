// =============================================================================
// WGSL 后处理着色器 — 灰度效果 (Post-Process: Grayscale Effect)
// =============================================================================
//
// 【后处理着色器概述】
// 后处理着色器是一种特殊的渲染技术：先将场景渲染到纹理（离屏渲染），
// 然后对该纹理应用各种图像处理效果。常见的后处理效果包括：
// 灰度化、模糊、泛光(Bloom)、色调映射、景深等。
//
// 【本文件功能】
// 简单的灰度（Grayscale）后处理效果。
// 将每个像素的 RGB 三个通道取平均值，转换为灰度色。
// 适用于"怀旧"、"黑白"等视觉效果。
//
// 【全屏四边形 (Full-Screen Quad)】
// 后处理通常使用一个覆盖整个屏幕的四边形来渲染。
// 该四边形的顶点坐标已经是 NDC（标准化设备坐标，范围 [-1, 1]），
// 因此顶点着色器不需要任何矩阵变换，直接传递位置即可。
// =============================================================================

// ---------------------------------------------------------------------------
// 顶点着色器输出结构体
// ---------------------------------------------------------------------------
// 对于后处理管线，顶点输出只需要：
//   - position: 屏幕位置（由全屏四边形的顶点坐标决定）
//   - texCoords: 纹理坐标（用于采样场景纹理）
struct VertexOut {
    // 裁剪空间位置，由于全屏四边形的坐标已经是 NDC 空间，
    // 直接赋值即可，无需矩阵变换
    @builtin(position) position: vec4f,
    // 纹理坐标，传递给片段着色器用于纹理采样
    @location(0) texCoords: vec2f
}

// ---------------------------------------------------------------------------
// 顶点着色器入口函数
// ---------------------------------------------------------------------------
// 后处理管线的顶点着色器非常简单：
// 全屏四边形的顶点坐标已经在 NDC 空间内（如 [-1,-1] 到 [1,1]），
// 所以只需将 pos 扩展为齐次坐标 (x, y, 0.0, 1.0) 直接输出。
@vertex 
fn vertexMain(
    @location(0) pos: vec2f,
    @location(1) texCoords: vec2f,
) -> VertexOut 
{ 
    var output : VertexOut; 

    // 将 2D 坐标扩展为齐次坐标 (x, y, z=0, w=1)
    // z=0 因为是 2D 全屏四边形，w=1 表示标准点（不做透视除法变换）
    output.position = vec4f(pos, 0.0, 1.0);
    output.texCoords = texCoords;

    return output;
}

// ---------------------------------------------------------------------------
// 片段着色器资源绑定
// ---------------------------------------------------------------------------
// 后处理只需要一个绑定组，包含一个采样器和一张纹理
// 这张纹理就是之前渲染管线的输出（场景渲染结果）
@group(0) @binding(0)
var texSampler: sampler;

@group(0) @binding(1)
var tex: texture_2d<f32>;

// ---------------------------------------------------------------------------
// 片段着色器入口函数 — 灰度化处理
// ---------------------------------------------------------------------------
// 灰度化算法：简单平均法
//   gray = (R + G + B) / 3.0
//
// 注意：这是一种最简单的灰度化方法，虽然不够精确（未考虑人眼感知权重），
// 但计算简单、效果直观。更精确的方法请参考主着色器中使用的
// ITU-R BT.601 亮度公式（0.299R + 0.587G + 0.114B）。
//
// 输出：@location(0) vec4f — 单个渲染目标的灰度颜色
@fragment
fn fragmentMain(fragData: VertexOut ) -> @location(0) vec4f 
{
    // 采样场景纹理，获取当前像素的颜色
    var screenTexture = textureSample(tex, texSampler, fragData.texCoords);

    // 计算灰度值：RGB 三通道取平均值
    var average = (screenTexture.r + screenTexture.g + screenTexture.b) / 3.0;

    // 输出灰度颜色，alpha 固定为 1.0（完全不透明）
    return vec4f(average, average, average, 1.0);
}
