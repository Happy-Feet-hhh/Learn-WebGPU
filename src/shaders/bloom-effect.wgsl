// =============================================================================
// WGSL 泛光合成着色器 (Bloom Composite Shader)
// =============================================================================
//
// 【Bloom（泛光）效果概述】
// Bloom 是一种模拟真实摄像机/人眼的光学效果：当画面中存在非常亮的区域时，
// 这些区域的亮度会"溢出"到周围像素，形成柔和的光晕。
//
// 【Bloom 渲染管线】
// 完整的 Bloom 效果通常包含以下步骤：
//   1. 场景渲染 → 同时输出颜色和亮度（shader.wgsl 的 MRT 输出）
//   2. 亮度提取 → 分离出亮度超过阈值的像素（shader.wgsl 的 brightness 输出）
//   3. 高斯模糊 → 对亮度纹理进行多次模糊（blur-effect.wgsl）
//   4. 最终合成 → 将原始场景与模糊后的亮度纹理合并（本文件）
//
// 【本文件功能】
// 将原始场景颜色与经过模糊处理的亮度纹理进行加法合成，产生最终的泛光效果。
// 关键技术：使用"减法技巧"避免亮像素区域被双重增亮。
// =============================================================================

// ---------------------------------------------------------------------------
// 顶点着色器输出结构体
// ---------------------------------------------------------------------------
struct VertexOut {
    @builtin(position) position: vec4f,
    @location(0) texCoords: vec2f
}

// ---------------------------------------------------------------------------
// 顶点着色器入口函数
// ---------------------------------------------------------------------------
// 后处理管线的标准顶点着色器：传递全屏四边形的 NDC 坐标
@vertex 
fn vertexMain(
    @location(0) pos: vec2f,
    @location(1) texCoords: vec2f,
) -> VertexOut 
{ 
    var output : VertexOut; 

    output.position = vec4f(pos, 0.0, 1.0);
    output.texCoords = texCoords;

    return output;
}

// ---------------------------------------------------------------------------
// 片段着色器资源绑定
// ---------------------------------------------------------------------------
// 绑定组 0：原始场景纹理（未经模糊的完整场景渲染结果）
// 包含场景中所有物体的颜色信息
@group(0) @binding(0)
var texSampler0: sampler;

@group(0) @binding(1)
var tex0: texture_2d<f32>;

// 绑定组 1：模糊后的亮度纹理
// 这张纹理经过了亮度提取 + 高斯模糊处理，包含柔和的光晕信息
@group(1) @binding(0)
var texSampler1: sampler;

@group(1) @binding(1)
var tex1: texture_2d<f32>;

// ---------------------------------------------------------------------------
// 片段着色器入口函数 — Bloom 最终合成
// ---------------------------------------------------------------------------
@fragment
fn fragmentMain(fragData: VertexOut ) -> @location(0) vec4f 
{
    // 采样原始场景颜色（只取 RGB 分量）
    var screenTexture = textureSample(tex0, texSampler0, fragData.texCoords).rgb;

    // 采样模糊后的亮度纹理（只取 RGB 分量）
    var brightnessBlurTexture = textureSample(tex1, texSampler1, fragData.texCoords).rgb;

    // =======================================================================
    // 减法技巧 (Subtraction Trick)
    // =======================================================================
    // screenTexture *= (1.0 - clamp(brightnessBlurTexture, 0.0, 1.0))
    //
    // 问题：如果直接将场景颜色与模糊亮度相加，原始场景中已经很亮的区域
    //       会被双重增亮（自身亮度 + 泛光亮度），导致过度曝光。
    //
    // 解决方案：在叠加泛光之前，先从场景颜色中减去对应的泛光贡献。
    //   1. clamp(brightnessBlurTexture, 0, 1) — 将模糊亮度限制在 [0, 1] 范围
    //   2. (1.0 - clamp(...)) — 计算保留系数：泛光越强的区域，保留系数越小
    //   3. screenTexture *= 保留系数 — 降低场景中泛光区域的亮度
    //
    // 效果：最终结果 = 降低后的场景 + 泛光亮度 ≈ 原始场景 + 新增的光晕
    // 避免了亮像素区域的过度增亮问题
    // =======================================================================
    screenTexture *= (vec3f(1.0) - clamp(brightnessBlurTexture, vec3f(0.0), vec3f(1.0)));

    // 加法合成：将处理后的场景颜色与模糊亮度纹理相加
    // 这是 Bloom 效果的核心 — 叠加柔和的光晕
    // 返回最终颜色，alpha 固定为 1.0
    return vec4f(screenTexture + brightnessBlurTexture , 1.0);
}
